# Prefer DATABASE_URL on Railway/Heroku (postgres:// is normalized automatically).
# DATABASE_URL=postgresql://reach:reach@localhost:5432/reach
#
# Or set discrete vars (DB_HOST must be set explicitly — there is no implicit localhost).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=reach
DB_USER=reach
DB_PASSWORD=reach
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters!!
JWT_EXPIRES_IN_DAYS=7
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
ROUTING_BASE_URL=https://router.project-osrm.org
